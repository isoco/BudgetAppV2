{
  "cli": {
    "version": ">= 18.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.18.0"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "env": {
        "JAVA_HOME": "/home/isoco/.jdk17",
        "ANDROID_HOME": "/home/isoco/android-sdk",
        "ANDROID_SDK_ROOT": "/home/isoco/android-sdk"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
